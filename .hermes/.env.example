# Hermes secrets — copy to ~/.hermes/.env (NEVER committed).
# Stow ignores .env / .env.local. Set via `hermes config set` to auto-route.

# LLM provider
ANTHROPIC_API_KEY=

# Discord gateway (decision elicitation + status notifications)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# Optional: OpenRouter for fallback provider routing
# OPENROUTER_API_KEY=
