# Hermes harness config — non-secret. Secrets in ~/.hermes/.env.
# Set values via `hermes config set <key> <value>` to route correctly.

model:
  default: "anthropic/claude-opus-4-7"
  # Context window minimum enforced by harness: 64k tokens. Opus at 200k.

terminal:
  # LOCKED to local (M6, decision 9). The pipeline-core plugin guards
  # registration on this — non-local backend = pipeline-core refuses to load.
  # Rationale: worktree git subprocess runs on host; terminal-tool writes must
  # be host-visible. docker / ssh backends break that invariant.
  backend: local
  timeout: 180

hooks_auto_accept: true

# Shell hooks. Read JSON envelope on stdin, optional JSON decision on stdout.
hooks:
  pre_tool_call:
    - matcher: "terminal"
      command: "~/.hermes/hooks/cap_bash_timeout.py"
      timeout: 5
    - matcher: "terminal"
      command: "~/.hermes/hooks/graphify_advice.sh"
      timeout: 3
    - matcher: "terminal"
      command: "~/.hermes/hooks/terminal_policy.py"
      timeout: 5
    - matcher: "terminal|patch|write_file"
      command: "~/.hermes/hooks/role_policy.py"
      timeout: 5

plugins:
  enabled:
    - pipeline-core

delegation:
  # Hierarchy: orchestrator (d0) -> role / reviewer-batch (d1). No nested
  # spawns. Two-axis reviewer uses tasks=[...] batch mode at d0 -> d1.
  max_spawn_depth: 2
  # K <= 4 shards per pipeline.
  max_concurrent_children: 4
  # Per-child iteration ceiling. Default 50 too low for shard builds.
  max_iterations: 100

# Skills discovery: stow-link `~/.hermes/skills/` only. No external_dirs —
# would double-register the same SKILL.md files (M8, decision 10).
