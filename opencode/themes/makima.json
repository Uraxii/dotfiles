{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#282828",
    "bg2": "#504945",
    "fg": "#f0e8d0",
    "fg_hi": "#FBF1C7",
    "fg_muted": "#a89984",
    "accent": "#d79921",
    "error": "#cc241d",
    "warning": "#fabd2f",
    "success": "#b8bb26",
    "info": "#83a598",
    "purple": "#b16286",
    "pink": "#d3869b",
    "aqua": "#8ec07c",
    "border": "#1d2021"
  },
  "theme": {
    "primary": {
      "dark": "accent",
      "light": "accent"
    },
    "secondary": {
      "dark": "pink",
      "light": "pink"
    },
    "accent": {
      "dark": "aqua",
      "light": "aqua"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "warning",
      "light": "warning"
    },
    "success": {
      "dark": "success",
      "light": "success"
    },
    "info": {
      "dark": "info",
      "light": "info"
    },
    "text": {
      "dark": "fg",
      "light": "fg"
    },
    "textMuted": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "background": {
      "dark": "none",
      "light": "none"
    },
    "backgroundPanel": {
      "dark": "none",
      "light": "none"
    },
    "backgroundElement": {
      "dark": "none",
      "light": "none"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "accent",
      "light": "accent"
    },
    "borderSubtle": {
      "dark": "bg2",
      "light": "bg2"
    },
    "diffAdded": {
      "dark": "success",
      "light": "success"
    },
    "diffRemoved": {
      "dark": "error",
      "light": "error"
    },
    "diffContext": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffHunkHeader": {
      "dark": "info",
      "light": "info"
    },
    "diffHighlightAdded": {
      "dark": "success",
      "light": "success"
    },
    "diffHighlightRemoved": {
      "dark": "error",
      "light": "error"
    },
    "diffAddedBg": {
      "dark": "none",
      "light": "none"
    },
    "diffRemovedBg": {
      "dark": "none",
      "light": "none"
    },
    "diffContextBg": {
      "dark": "none",
      "light": "none"
    },
    "diffLineNumber": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "none",
      "light": "none"
    },
    "diffRemovedLineNumberBg": {
      "dark": "none",
      "light": "none"
    },
    "markdownText": {
      "dark": "fg",
      "light": "fg"
    },
    "markdownHeading": {
      "dark": "accent",
      "light": "accent"
    },
    "markdownLink": {
      "dark": "info",
      "light": "info"
    },
    "markdownLinkText": {
      "dark": "aqua",
      "light": "aqua"
    },
    "markdownCode": {
      "dark": "success",
      "light": "success"
    },
    "markdownBlockQuote": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownEmph": {
      "dark": "warning",
      "light": "warning"
    },
    "markdownStrong": {
      "dark": "fg_hi",
      "light": "fg_hi"
    },
    "markdownHorizontalRule": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownListItem": {
      "dark": "accent",
      "light": "accent"
    },
    "markdownListEnumeration": {
      "dark": "warning",
      "light": "warning"
    },
    "markdownImage": {
      "dark": "info",
      "light": "info"
    },
    "markdownImageText": {
      "dark": "aqua",
      "light": "aqua"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxComment": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "syntaxKeyword": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxFunction": {
      "dark": "info",
      "light": "info"
    },
    "syntaxVariable": {
      "dark": "fg_hi",
      "light": "fg_hi"
    },
    "syntaxString": {
      "dark": "success",
      "light": "success"
    },
    "syntaxNumber": {
      "dark": "warning",
      "light": "warning"
    },
    "syntaxType": {
      "dark": "aqua",
      "light": "aqua"
    },
    "syntaxOperator": {
      "dark": "accent",
      "light": "accent"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    }
  }
}
