{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/skills/caveman/SKILL.md",
    "~/dotfiles/CLAUDE.md"
  ],
  "default_agent": "orchestrator",
  "permission": {
    "external_directory": {
      "~/.pipeline/**": "allow",
      "**/.pipeline/**": "allow"
    },
    "edit": {
      "*": "ask",
      ".pipeline/**": "allow",
      "~/.pipeline/**": "allow",
      "**/.pipeline/**": "allow"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "mkdir *.pipeline/runs/*": "allow",
      "mkdir *.pipeline/plans/*": "allow",
      "mkdir -p *.pipeline/runs/*": "allow",
      "mkdir -p *.pipeline/plans/*": "allow",
      "pwd": "allow",
      "git rev-parse*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git worktree add*": "ask",
      "git worktree list*": "allow",
      "git worktree remove*": "ask",
      "gh pr create*": "ask",
      "gh pr view*": "ask",
      "gh pr list*": "ask",
      "gh pr comment*": "ask",
      "gh pr close*": "ask",
      "gh pr edit*": "ask",
      "gh pr merge*": "ask",
      "gh auth status*": "ask",
      "gh auth login*": "ask",
      "gh auth logout*": "ask",
      "gh auth setup-git*": "ask",
      "gh repo view*": "ask",
      "gh repo clone*": "ask",
      "gh repo delete*": "ask",
      "python3 ~/.config/opencode/tools/artifact-slug.py*": "ask",
      "python3 ~/.config/opencode/tools/verdict-parse.py*": "ask",
      "python3 ~/.config/opencode/tools/test-path-resolve.py*": "ask",
      "python3 ~/.config/opencode/tools/handoff-doc.py*": "ask",
      "python3 ~/.config/opencode/tools/prod-diff-sha.py*": "ask",
      "python3 ~/.config/opencode/tools/worktree-lifecycle.py*": "ask"
    },
    "write": {
      "*": "ask",
      ".pipeline/**": "allow",
      "~/.pipeline/**": "allow",
      "**/.pipeline/**": "allow"
    },
    "webfetch": "ask"
  },
  "agent": {
    "orchestrator": {
      "permission": {
        "artifact-slug": "allow",
        "verdict-parse": "allow",
        "worktree-lifecycle": "allow",
        "prod-diff-sha": "allow",
        "handoff-doc": "allow",
        "test-path-resolve": "allow",
        "task": {
          "*": "deny",
          "plan": "allow",
          "architect": "allow",
          "build": "allow",
          "skeptic": "allow",
          "tester": "allow",
          "reviewer": "allow",
          "security-auditor": "allow",
          "ui-ux-designer": "allow",
          "researcher": "allow",
          "friction-reviewer": "allow",
          "progenitor": "allow",
          "content-designer": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "artifact-slug": "allow",
        "verdict-parse": "allow"
      }
    },
    "architect": {
      "permission": {
        "verdict-parse": "allow",
        "handoff-doc": "allow"
      }
    },
    "build": {
      "permission": {
        "verdict-parse": "allow",
        "worktree-lifecycle": "allow",
        "test-path-resolve": "allow",
        "handoff-doc": "allow"
      }
    },
    "skeptic": {
      "permission": {
        "verdict-parse": "allow",
        "test-path-resolve": "allow",
        "prod-diff-sha": "allow"
      }
    },
    "tester": {
      "permission": {
        "verdict-parse": "allow",
        "test-path-resolve": "allow",
        "prod-diff-sha": "allow"
      }
    },
    "reviewer": {
      "permission": {
        "verdict-parse": "allow"
      }
    },
    "security-auditor": {
      "permission": {
        "verdict-parse": "allow"
      }
    },
    "ui-ux-designer": {
      "permission": {
        "verdict-parse": "allow"
      }
    },
    "researcher": {
      "permission": {}
    },
    "friction-reviewer": {
      "permission": {
        "verdict-parse": "allow"
      }
    },
    "progenitor": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "content-designer": {
      "permission": {}
    }
  }
}
