{
    "reload_style_on_change": true,
    "exclusive": true,
    "position": "top",
    "spacing": 0,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "margin-left": 0,

    "modules-left": [
        "group/left2"
    ],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["group/right1", "group/right"],

    "group/left2": {
        "orientation": "inherit",
        "modules": ["power-profiles-daemon", "bluetooth", "network"]
    },

    "group/right1": {
        "orientation": "inherit",
        "modules": ["tray"]
    },

    "group/right": {
        "orientation": "inherit",
        "modules": ["pulseaudio", "backlight", "memory", "cpu", "battery", "clock"]
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "дёҖ",
            "2": "дәҢ",
            "3": "дёү",
            "4": "еӣӣ",
            "5": "дә”",
            "6": "е…ӯ",
            "7": "дёғ",
            "8": "е…«",
            "9": "д№қ",
            "10": "еҚҒ"
        }
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "performance": " у°“… ",
            "balanced": " у°ҫ… ",
            "power-saver": " у°ҢӘ "
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%d %B %Y}",
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "format": {
                "month": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#d79921'><b>{}</b></span>",
                "today": "<span color='#cc241d'><b>{}</b></span>"
            }
        }
    },

    "bluetooth": {
        "format": " у°ӮҜ ",
        "format-connected": " у°Ӯұ ",
        "format-disabled": " у°ӮІ ",
        "tooltip-format": "{controller_alias}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-icons": ["у°ӨҜ", "у°Өҹ", "у°Өў", "у°ӨҘ", "у°ӨЁ"],
        "format-wifi": "{icon} ",
        "format-ethernet": " у°ҲҖ ",
        "format-disconnected": " у°Ө® ",
        "tooltip-format-wifi": "{essid}\nвҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "вҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "networkmanager_dmenu",
        "interval": 3
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "у°қҹ",
        "format-icons": {
            "default": [" у°•ҝ ", " у°–Җ ", " у°•ҫ "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pamixer -t",
        "scroll-step": 5,
        "tooltip-format": "{volume}%"
    },

    "memory": {
        "interval": 5,
        "format": " у°ҳҡ {used:0.1f}G"
    },

    "cpu": {
        "interval": 5,
        "format": " у°Қӣ {usage}%"
    },

    "battery": {
        "interval": 5,
        "format": "{icon} {capacity}%",
        "format-charging": " у°Ӯ„ {capacity}%",
        "format-full": " у°Ғ№ {capacity}%",
        "format-icons": ["у°Ғә", "у°Ғ»", "у°Ғј", "у°ҒҪ", "у°Ғҫ", "у°Ғҝ", "у°ӮҖ", "у°ӮҒ", "у°ӮӮ", "у°Ғ№"],
        "tooltip-format-discharging": "{power:>1.0f}W  {timeTo}",
        "tooltip-format-charging": "{power:>1.0f}W  {timeTo}",
        "states": {
            "good": 80,
            "low": 20,
            "critical": 10
        }
    },

    "backlight": {
        "format": " {icon} {percent}%",
        "format-icons": ["у°ғһ", "у°ғҹ", "у°ғ "],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "tray": {
        "icon-size": 11,
        "spacing": 5
    }
}
