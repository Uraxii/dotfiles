{
    "reload_style_on_change": true,
    "exclusive": true,
    "position": "top",
    "spacing": 0,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "margin-left": 0,

    "modules-left": [
        "group/left1",
        "group/left2"
    ],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["group/right1", "group/right"],

    "group/left1": {
        "orientation": "inherit",
        "modules": ["clock"]
    },

    "group/left2": {
        "orientation": "inherit",
        "modules": ["power-profiles-daemon", "network"]
    },

    "group/right1": {
        "orientation": "inherit",
        "modules": ["tray"]
    },

    "group/right": {
        "orientation": "inherit",
        "modules": ["pulseaudio", "memory", "cpu", "battery"]
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
