{
    "reload_style_on_change": true,
    "exclusive": true,
    "position": "top",
    "spacing": 0,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "margin-left": 0,

    "modules-left": [
        "group/left2"
    ],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["group/right1", "group/right"],

    "group/left2": {
        "orientation": "inherit",
        "modules": ["power-profiles-daemon", "custom/sep", "bluetooth", "custom/sep", "network"]
    },

    "group/right1": {
        "orientation": "inherit",
        "modules": ["tray"]
    },

    "group/right": {
        "orientation": "inherit",
        "modules": ["pulseaudio", "custom/sep", "backlight", "custom/sep", "memory", "custom/sep", "cpu", "custom/sep", "battery", "custom/sep", "clock"]
    },

    "custom/sep": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "一",
            "2": "二",
            "3": "三",
            "4": "四",
            "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十"
        }
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "performance": " 󰓅 ",
            "balanced": " 󰾅 ",
            "power-saver": " 󰌪 "
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%d %B %Y}",
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "format": {
                "month": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#d79921'><b>{}</b></span>",
                "today": "<span color='#cc241d'><b>{}</b></span>"
            }
        }
    },

    "bluetooth": {
        "format": " 󰂯 ",
        "format-connected": " 󰂱 ",
        "format-disabled": " 󰂲 ",
        "tooltip-format": "{controller_alias}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
        "format-wifi": "{icon} ",
        "format-ethernet": " 󰈀 ",
        "format-disconnected": " 󰤮 ",
        "tooltip-format-wifi": "{essid}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-ethernet": "⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "networkmanager_dmenu",
        "interval": 3
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "default": [" 󰕿 ", " 󰖀 ", " 󰕾 "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pamixer -t",
        "scroll-step": 5,
        "tooltip-format": "{volume}%"
    },

    "memory": {
        "interval": 5,
        "format": " 󰘚 {used:0.1f}G"
    },

    "cpu": {
        "interval": 5,
        "format": " 󰍛 {usage}%"
    },

    "battery": {
        "interval": 5,
        "format": "{icon} {capacity}%",
        "format-charging": " 󰂄 {capacity}%",
        "format-full": " 󰁹 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format-discharging": "{power:>1.0f}W  {timeTo}",
        "tooltip-format-charging": "{power:>1.0f}W  {timeTo}",
        "states": {
            "good": 80,
            "low": 20,
            "critical": 10
        }
    },

    "backlight": {
        "format": " {icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "tray": {
        "icon-size": 11,
        "spacing": 5
    }
}
