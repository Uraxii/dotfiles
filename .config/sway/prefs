### Theme
set $theme manjaro
# Waybar layout (HANCORE-linux/waybar-themes). Any subdir name under
# .config/waybar/themes/ (V1, V2.5, V3.6a, V7, ...). Each ships its own
# config.jsonc + style.css; colors come from $theme via shim.
set $waybar_theme V3.1d

### Default Applications
set $term ghostty

### Font
set $font_family "0xProto Nerd Font"
font pango:0xProto Nerd Font 16

# Your preferred application launcher
set $menu wofi --show drun

set $explorer thunar
set $browser io.github.zen_browser.zen

### Swaybg
# https://man.archlinux.org/man/swaybg.1.en
set $wallpaper ~/.local/share/wallpaper
set $wallpaper_mode fill


### Power
set $lock_system_delay 10
set $turn_display_off_delay 600


### Cursor
seat seat0 xcursor_theme posy-black 24


### Keybinds
# Logo key. Use Mod1 for Alt.
set $mod Mod4

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

