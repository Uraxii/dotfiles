version = 3

[upgrade]
  source = 'cdn'
  interval = '168h'
  auto = false
  notice = false

[transient_prompt]
  background = "transparent"
  foreground = "##FG##"
  template = " {{ .Folder }}> "
  newline = false

[[blocks]]
  type = 'prompt'
  alignment = 'left'

  [[blocks.segments]]
    leading_diamond = '╭─'
    template = ' {{ .Name }} '
    foreground = '##FG##'
    background = '##PRIMARY##'
    type = 'shell'
    style = 'diamond'

  [[blocks.segments]]
    template = '<parentBackground></>  '
    foreground = '#FFFB38'
    background = '##ERROR##'
    type = 'root'
    style = 'diamond'

  [[blocks.segments]]
    template = '  {{ .Path }} '
    foreground = '##PATH_FG##'
    powerline_symbol = ''
    background = '##PATH_BG##'
    type = 'path'
    style = 'powerline'

    [blocks.segments.properties]
      folder_icon = '  '
      home_icon = ''
      style = 'folder'

  [[blocks.segments]]
    template = ' {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<##ERROR##>  {{ .Staging.String }}</>{{ end }} '
    foreground = '##GIT_FG##'
    powerline_symbol = ''
    background = '##GIT_BG##'
    type = 'git'
    style = 'powerline'
    background_templates = ['{{ if or (.Working.Changed) (.Staging.Changed) }}##GIT_DIRTY##{{ end }}', '{{ if and (gt .Ahead 0) (gt .Behind 0) }}##GIT_AHEAD##{{ end }}', '{{ if gt .Ahead 0 }}##GIT_AHEAD##{{ end }}', '{{ if gt .Behind 0 }}##GIT_AHEAD##{{ end }}']

    [blocks.segments.properties]
      branch_icon = ' '
      fetch_status = true
      fetch_upstream_icon = true

  [[blocks.segments]]
    trailing_diamond = ''
    template = '  {{ .FormattedMs }}⠀'
    foreground = '##FG##'
    background = '##MUTED##'
    type = 'executiontime'
    style = 'diamond'

    [blocks.segments.properties]
      style = 'roundrock'
      threshold = 0.0

[[blocks]]
  type = 'prompt'
  alignment = 'right'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}'
    foreground = '#3C873A'
    background = '#303030'
    type = 'node'
    style = 'diamond'

    [blocks.segments.properties]
      fetch_package_manager = true
      npm_icon = ' <#cc3a3a></> '
      yarn_icon = ' <#348cba></>'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}'
    foreground = '#FFE873'
    background = '#306998'
    type = 'python'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#ffffff'
    background = '#0e8ac8'
    type = 'java'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Unsupported }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#0d6da8'
    background = '#0e0e0e'
    type = 'dotnet'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#06aad5'
    background = '#ffffff'
    type = 'go'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#925837'
    background = '#f3f0ec'
    type = 'rust'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ' '
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#055b9c'
    background = '#e1e8e9'
    type = 'dart'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ' '
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#ce092f'
    background = '#ffffff'
    type = 'angular'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ' '
    trailing_diamond = ' '
    template = 'α {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#de1f84'
    background = '#ffffff'
    type = 'aurelia'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ' '
    trailing_diamond = ' '
    template = '{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}'
    foreground = '#ffffff'
    background = '#1e293b'
    type = 'nx'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ' '
    trailing_diamond = ' '
    template = '<#ca3c34></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#359a25'
    background = '#945bb3'
    type = 'julia'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#9c1006'
    background = '#ffffff'
    type = 'ruby'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = '<#f5bf45></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}'
    foreground = '#5398c2'
    background = '#ffffff'
    type = 'azfunc'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ' '
    template = ' {{.Profile}}{{if .Region}}@{{.Region}}{{end}}'
    foreground = '#faa029'
    background = '#565656'
    type = 'aws'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ''
    template = ' {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}'
    foreground = '#ffffff'
    background = '#316ce4'
    type = 'kubectl'
    style = 'diamond'

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = '<transparent,background></>'
    template = ' {{ if .WSL }}{{.Icon}}(WSL){{ end }} '
    foreground = '##FG_DARK##'
    background = '##OS_BG##'
    type = 'os'
    style = 'diamond'

    [blocks.segments.properties]
      linux = ''
      redhat = '󱄛'
      arch = '󰣇'
      manjaro = '󱘊'
      ubuntu = '󰕈'
      macos = ''
      windows = ''

  [[blocks.segments]]
    template = ' {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }} '
    foreground = '#262626'
    powerline_symbol = ''
    background = '##ERROR##'
    type = 'battery'
    style = 'powerline'
    background_templates = ['{{if eq "Charging" .State.String}}#b8e994{{end}}', '{{if eq "Discharging" .State.String}}{{if ge .Percentage 50}}#77DD77{{end}}{{end}}', '{{if eq "Full" .State.String}}#77DD77{{end}}']
    invert_powerline = true

    [blocks.segments.properties]
      charged_icon = '󰁹 '
      charging_icon = '󰂄 '
      discharging_icon = '󰁹 '

  [[blocks.segments]]
    leading_diamond = ''
    trailing_diamond = ''
    template = '  {{ .CurrentDate | date .Format }} '
    foreground = '##FG##'
    background = '##PRIMARY##'
    type = 'time'
    style = 'diamond'
    invert_powerline = true

    [blocks.segments.properties]
      time_format = '_2,15:04'

[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    template = '╰─'
    foreground = '##PRIMARY##'
    type = 'text'
    style = 'plain'

  [[blocks.segments]]
    template = ' '
    foreground = '##FG##'
    type = 'status'
    style = 'plain'
    foreground_templates = ['{{ if gt .Code 0 }}##ERROR##{{ end }}']

    [blocks.segments.properties]
      always_enabled = true
