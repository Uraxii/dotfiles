{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#0d0b1a",
    "bg2": "#1a1530",
    "fg": "#e8e0f0",
    "fg_hi": "#f5f0ff",
    "fg_muted": "#6e6580",
    "primary": "#e6207a",
    "success": "#2eb398",
    "warning": "#d4a017",
    "info": "#2196a6",
    "blue": "#1a237e",
    "purple": "#7b2fbe",
    "pink": "#e6207a",
    "error": "#ff1493",
    "border": "#090714"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "pink",
      "light": "pink"
    },
    "accent": {
      "dark": "info",
      "light": "info"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "warning",
      "light": "warning"
    },
    "success": {
      "dark": "success",
      "light": "success"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "fg",
      "light": "fg"
    },
    "textMuted": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "background": {
      "dark": "none",
      "light": "none"
    },
    "backgroundPanel": {
      "dark": "none",
      "light": "none"
    },
    "backgroundElement": {
      "dark": "none",
      "light": "none"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "primary",
      "light": "primary"
    },
    "borderSubtle": {
      "dark": "bg2",
      "light": "bg2"
    },
    "diffAdded": {
      "dark": "success",
      "light": "success"
    },
    "diffRemoved": {
      "dark": "error",
      "light": "error"
    },
    "diffContext": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffHunkHeader": {
      "dark": "purple",
      "light": "purple"
    },
    "diffHighlightAdded": {
      "dark": "success",
      "light": "success"
    },
    "diffHighlightRemoved": {
      "dark": "error",
      "light": "error"
    },
    "diffAddedBg": {
      "dark": "none",
      "light": "none"
    },
    "diffRemovedBg": {
      "dark": "none",
      "light": "none"
    },
    "diffContextBg": {
      "dark": "none",
      "light": "none"
    },
    "diffLineNumber": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "none",
      "light": "none"
    },
    "diffRemovedLineNumberBg": {
      "dark": "none",
      "light": "none"
    },
    "markdownText": {
      "dark": "fg",
      "light": "fg"
    },
    "markdownHeading": {
      "dark": "primary",
      "light": "primary"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "info",
      "light": "info"
    },
    "markdownCode": {
      "dark": "success",
      "light": "success"
    },
    "markdownBlockQuote": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownEmph": {
      "dark": "warning",
      "light": "warning"
    },
    "markdownStrong": {
      "dark": "fg_hi",
      "light": "fg_hi"
    },
    "markdownHorizontalRule": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownListItem": {
      "dark": "primary",
      "light": "primary"
    },
    "markdownListEnumeration": {
      "dark": "warning",
      "light": "warning"
    },
    "markdownImage": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownImageText": {
      "dark": "info",
      "light": "info"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxComment": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "syntaxKeyword": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "fg_hi",
      "light": "fg_hi"
    },
    "syntaxString": {
      "dark": "success",
      "light": "success"
    },
    "syntaxNumber": {
      "dark": "warning",
      "light": "warning"
    },
    "syntaxType": {
      "dark": "info",
      "light": "info"
    },
    "syntaxOperator": {
      "dark": "primary",
      "light": "primary"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    }
  }
}
