{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["~/.config/opencode/skills/caveman/SKILL.md"],
  "default_agent": "orchestrator",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "write": "ask",
    "webfetch": "ask"
  },
  "agent": {
    "orchestrator": {
      "description": "Root orchestrator. Triage direct vs pipeline and route stages.",
      "mode": "primary",
      "color": "primary",
      "model": "##MODEL_ORCHESTRATOR##",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow",
        "webfetch": "ask"
      },
      "prompt": "{file:./prompts/orchestrator.md}"
    },
    "plan": {
      "description": "Scope and task breakdown. No code changes.",
      "mode": "all",
      "color": "accent",
      "model": "##MODEL_PLAN##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/plan.md}"
    },
    "build": {
      "description": "Implement production code and tests.",
      "mode": "all",
      "color": "success",
      "model": "##MODEL_BUILD##",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow",
        "webfetch": "ask"
      },
      "prompt": "{file:./prompts/build.md}",
      "skill": {
        "frontend-design": "allow"
      }
    },
    "researcher": {
      "description": "Pre-plan domain research and external system checks.",
      "mode": "all",
      "color": "accent",
      "model": "##MODEL_RESEARCHER##",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "write": "deny",
        "webfetch": "allow"
      },
      "prompt": "{file:./prompts/researcher.md}"
    },
    "architect": {
      "description": "System architecture, ADRs, contracts, tradeoffs.",
      "mode": "subagent",
      "color": "secondary",
      "model": "##MODEL_ARCHITECT##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/architect.md}"
    },
    "skeptic": {
      "description": "Critical gatekeeper for design/code/ops reviews.",
      "mode": "subagent",
      "color": "warning",
      "model": "##MODEL_SKEPTIC##",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/skeptic.md}"
    },
    "reviewer": {
      "description": "Code quality and maintainability review gate.",
      "mode": "subagent",
      "color": "info",
      "model": "##MODEL_REVIEWER##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/reviewer.md}"
    },
    "security-auditor": {
      "description": "Security review gate and threat checks.",
      "mode": "subagent",
      "color": "error",
      "model": "##MODEL_SECURITY_AUDITOR##",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "write": "allow",
        "webfetch": "ask"
      },
      "prompt": "{file:./prompts/security-auditor.md}"
    },
    "tester": {
      "description": "Test strategy and validation after gates pass.",
      "mode": "subagent",
      "color": "success",
      "model": "##MODEL_TESTER##",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/tester.md}"
    },
    "friction-reviewer": {
      "description": "Pipeline process review and improvement suggestions.",
      "mode": "subagent",
      "color": "secondary",
      "model": "##MODEL_FRICTION_REVIEWER##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/friction-reviewer.md}"
    },
    "monitor": {
      "description": "Memory hygiene and cross-cutting pattern monitor.",
      "mode": "subagent",
      "color": "accent",
      "model": "##MODEL_MONITOR##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/monitor.md}"
    },
    "progenitor": {
      "description": "Creates and evolves agent role definitions.",
      "mode": "primary",
      "color": "primary",
      "model": "##MODEL_PROGENITOR##",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "write": "allow",
        "webfetch": "deny"
      },
      "prompt": "{file:./prompts/progenitor.md}"
    },
    "code-reviewer": {
      "description": "Manual code review helper.",
      "mode": "subagent",
      "color": "warning",
      "model": "##MODEL_CODE_REVIEWER##",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "deny",
        "webfetch": "deny"
      }
    }
  }
}
