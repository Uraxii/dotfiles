*.local
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.claude/*local*
.claude/**/*local*
.config/opencode/projects/*
!.config/opencode/projects/.gitkeep
.config/configstore
.config/uv
.config/opencode/plans/*
!.config/opencode/plans/.gitkeep
.config/opencode/memory/*
!.config/opencode/memory/.gitkeep
.config/opencode/agents/memory/*
!.config/opencode/agents/memory/.gitkeep
.config/opencode/agents/shared/agent-models.local.json
.config/opencode/agents/shared/model-map.local.md
.config/opencode/inbox/
.config/opencode/opencode.json
.config/opencode/models.local
messages.md

.claude/plans
.claude/projects
# claude-code runtime state (written into ~/.claude/ at runtime; never tracked)
.claude/.credentials.json
.claude/cache/
.claude/debug/
.claude/history.jsonl
.claude/plugins/
.claude/session-env/
.claude/statsig/
.claude/todos/
# Ignore .pipeline/ runtime dirs but keep _shared/ SSoT source tracked
.pipeline/runs/
.pipeline/dreams/
.pipeline/memory/
# Catch any other .pipeline/ children that aren't explicitly tracked
.pipeline/*
!/.pipeline/_shared/
!/.pipeline/_shared/**
# OpenCode pipeline-aware config tracked; runtime overrides still in .local variants
!/.config/opencode/opencode.json

# Slack listener: per-run runtime state never tracked.
# State, pid, and log files live under <run-dir>, which is already covered by
# .pipeline/runs/ above. Tokens at ~/.claude/pipeline/slack.env.local are
# handled by the .claude/**/*local* rule above.
