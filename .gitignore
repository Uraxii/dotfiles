*.local
__pycache__/
*.pyc
*.pyo
.pytest_cache/
# uv-managed virtualenv — regenerated by `uv sync`. uv.lock IS tracked.
.venv/
# zsh completion cache — regenerated on shell startup, machine-specific
zsh/.zcompdump*
.claude/*local*
.claude/**/*local*
# .stow-local-ignore is stow's package-level ignore file — DO track it.
!.claude/.stow-local-ignore
!.hermes/.stow-local-ignore
opencode/projects/*
!opencode/projects/.gitkeep
configstore
uv
opencode/plans/*
!opencode/plans/.gitkeep
opencode/memory/*
!opencode/memory/.gitkeep
opencode/agents/memory/*
!opencode/agents/memory/.gitkeep
opencode/agents/shared/agent-models.local.json
opencode/agents/shared/model-map.local.md
opencode/inbox/
opencode/opencode.json
opencode/models.local
messages.md

# tpm-installed tmux plugins — runtime install, never tracked
tmux/plugins/

.claude/plans
.claude/projects
# claude-code runtime state (written into ~/.claude/ at runtime; never tracked)
.claude/.credentials.json
.claude/cache/
.claude/debug/
.claude/history.jsonl
.claude/plugins/
.claude/session-env/
.claude/statsig/
.claude/todos/
.claude/backups/
.claude/file-history/
.claude/sessions/
.claude/shell-snapshots/
.claude/mcp-needs-auth-cache.json
# Ignore .pipeline/ runtime dirs but keep _shared/ SSoT source tracked
.pipeline/runs/
.pipeline/dreams/
.pipeline/memory/
# Catch any other .pipeline/ children that aren't explicitly tracked
.pipeline/*
!/.pipeline/_shared/
!/.pipeline/_shared/**
# OpenCode pipeline-aware config tracked; runtime overrides still in .local variants
!/opencode/opencode.json

# Slack listener: per-run runtime state never tracked.
# State, pid, and log files live under <run-dir>, which is already covered by
# .pipeline/runs/ above. Tokens at ~/.claude/pipeline/slack.env.local are
# handled by the .claude/**/*local* rule above.

# Hermes runtime + secrets — never tracked
.hermes/.env
.hermes/.env.local
.hermes/state.db
.hermes/sessions/
.hermes/memory/
.hermes/pipeline-registry.json
.hermes/*local*
# .stow-local-ignore is stow's package-level ignore file — DO track it.
!.hermes/.stow-local-ignore
.hermes/channel_directory.json
.hermes/cron/
.hermes/kanban.db
.hermes/kanban.db-shm
.hermes/kanban.db-wal
# Local-only live config; SOUL.md identity files are static and tracked.
.hermes/config.yaml
.hermes/profiles/*/config.yaml
.hermes/profiles/*/.env
.hermes/profiles/*/state.db
.hermes/profiles/*/sessions/
.hermes/profiles/*/memory/
.hermes/profiles/*/logs/
.hermes/profiles/*/auth.json

# graphify generated knowledge-graph output (not source)
graphify-out/

# Scratch / build artifacts (never tracked)
copilot.zip
tmp/
zsh/.zcompdump

# spike runtime junk
spikes/beads-board/node_modules/
spikes/commit-linter/testbed/
