## Synthwave '84 Theme
## Palette source: https://github.com/robb0wen/synthwave-vscode
## Directory name kept as `manjaro` for sway/prefs stability.

# Colors
set $bg          #2a2139
set $bg_2        #34294f
set $fg          #f0eff1
set $fg_1        #ffffff
set $fg_2        #b6b1c1
set $magenta     #ff7edb
set $green       #72f1b8
set $yellow      #fede5d
set $blue        #495495
set $blue_faded  #1a1428
set $purple      #b893ce
set $aqua        #03edf9
set $gray        #848bbd
set $darkgray    #1a1428
set $pink        #fe4450

# Class                 border    bground   text    indicator  child_border
client.focused          $magenta  $magenta  $bg     $purple    $magenta
client.focused_inactive $bg_2     $bg       $gray   $bg_2      $bg_2
client.unfocused        $darkgray $bg       $gray   $darkgray  $darkgray
client.urgent           $pink     $pink     $fg_1   $pink      $pink
client.placeholder      $darkgray $darkgray $fg     $darkgray  $darkgray
