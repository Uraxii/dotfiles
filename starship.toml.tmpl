# Generated by set-theme.sh from this template. Do not edit ~/.config/starship.toml
# Source of truth: ~/dotfiles/.config/starship.toml.tmpl
# Base: https://raw.githubusercontent.com/omerxx/dotfiles/master/starship/starship.toml
# Added: battery + time modules (right prompt) + multi-palette theming hook.

"$schema" = 'https://starship.rs/config-schema.json'

add_newline = false

# Minimal prompt: directory + char only. All status info (git branch, user,
# battery, clock) lives in the tmux top status bar — see ~/.config/tmux/tmux.conf.
# right_format intentionally empty.
format = """$directory$character"""
right_format = ""

# Palette selected by sway theme via set-theme.sh template substitution.
palette = "##PALETTE##"

command_timeout = 1000

[character]
vicmd_symbol = "[N] >>>"
success_symbol = '[➜](bold green)'

[git_branch]
format = '[$symbol$branch(:$remote_branch)]($style)'

[aws]
format = '[$symbol(profile: "$profile" )(\(region: $region\) )]($style)'
disabled = false
style = 'bold blue'
symbol = " "

[golang]
format = '[ ](bold cyan)'

[kubernetes]
symbol = '☸ '
disabled = true
detect_files = ['Dockerfile']
format = '[$symbol$context( \($namespace\))]($style) '

[docker_context]
disabled = true

# --- requested additions: battery + date/time on right prompt --------------

[battery]
disabled = false
full_symbol = " "
charging_symbol = "󰂄 "
discharging_symbol = "󰁹 "
unknown_symbol = "󰁽 "
empty_symbol = "󰂃 "
format = '[$symbol$percentage]($style) '

[[battery.display]]
threshold = 20
style = 'bold red'

[[battery.display]]
threshold = 50
style = 'bold yellow'

[[battery.display]]
threshold = 100
style = 'bold green'

[time]
disabled = false
format = '[ $time]($style) '
time_format = "%Y-%m-%d %H:%M"
style = "bold lavender"
utc_time_offset = "local"

