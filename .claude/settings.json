{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "86400000"
  },
  "permissions": {
    "allow": [
      "Read(~/.pipeline/**)",
      "Write(~/.pipeline/**)",
      "Edit(~/.pipeline/**)",
      "Read(.pipeline/**)",
      "Write(.pipeline/**)",
      "Edit(.pipeline/**)",
      "Read(CLAUDE.md)",
      "Read(.claude/**)",
      "Read(docs/adr/**)",
      "Read(CONTRIBUTING.md)",
      "Write(docs/adr/**)",
      "Edit(docs/adr/**)",
      "Edit(.claude/agents/**)",
      "Write(.claude/agents/**)",
      "Edit(.claude/skills/**)",
      "Write(.claude/skills/**)",
      "Edit(.claude/templates/**)",
      "Write(.claude/templates/**)",
      "Bash(git rev-parse:*)",
      "Bash(git worktree:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git update-ref:*)",
      "Bash(git reset --soft:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git status)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git merge:*)",
      "Bash(git show:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh auth status)",
      "Bash(gh api:*)",
      "Bash(printf:*)",
      "Bash(sha1sum:*)",
      "Bash(mktemp:*)",
      "Bash(mkdir:*)",
      "Bash(mkdir -p:*)",
      "Bash(command -v:*)",
      "Bash(python3 ~/.config/opencode/tools/artifact-slug.py*)",
      "Bash(python3 ~/.claude/pipeline/pipeline_ask.py:*)",
      "Bash(~/.claude/pipeline/pipeline_ask.py:*)",
      "Bash(wc:*)",
      "Bash(test -f:*)",
      "Bash(test -d:*)",
      "Bash(test ! -f:*)",
      "Bash(jq:*)",
      "Bash(npm test:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn test:*)",
      "Bash(bun test:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(cargo test:*)",
      "Bash(go test:*)",
      "Bash(dotnet test:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf /:)"
    ]
  },
  "model": "claude-opus-4-7[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cap_bash_timeout.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "git",
        "url": "https://github.com/JuliusBrussee/caveman.git"
      }
    }
  },
  "effortLevel": "high",
  "agent": "orchestrator",
  "skipDangerousModePermissionPrompt": true,
  "theme": "custom:manjaro",
  "skipAutoPermissionPrompt": true,
  "effort": "high"
}
