# Pipeline Slack listener environment file.
#
# Copy to slack.env.local (NOT slack.env) in this same directory, fill values, chmod 600.
#   cp ~/.claude/pipeline/slack.env.example ~/.claude/pipeline/slack.env.local
#   chmod 600 ~/.claude/pipeline/slack.env.local
#
# The .local suffix matches both .gitignore (.claude/**/*local*) and
# .stow-local-ignore (\.claude/.*local.*). Real tokens never tracked, never stowed.
#
# Tokens obtained at https://api.slack.com/apps after creating the app:
#   1. Create app from scratch (or import slack-app-manifest.yaml).
#   2. OAuth & Permissions -> Bot Token Scopes:
#        chat:write          (post msgs)
#        chat:write.public   (post to public channels w/o being member)
#        channels:history    (Phase 2 - free-text thread replies; optional today)
#        groups:history      (Phase 2 - free-text thread replies; optional today)
#        files:read          (required for pipeline_ask.py --attach)
#        files:write         (required for pipeline_ask.py --attach)
#   3. Install to Workspace -> copy "Bot User OAuth Token" (xoxb-...).
#   4. Settings -> Socket Mode -> Enable.
#   5. Generate App-Level Token with scope: connections:write -> copy xapp-...
#   6. Features -> Interactivity & Shortcuts -> On (no Request URL needed; Socket Mode handles).
#
# Bot must be invited to each channel listed in any project's pipeline.toml:
#   /invite @your-bot-name
# (file uploads require channel membership; chat:write.public covers posting only).

SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me

# Default channel ID for all projects. Right-click channel in Slack ->
# View details -> bottom shows the C... ID. Bot must be invited to this
# channel (/invite @your-bot-name).
#
# Per-project override: set [slack].channel in <project>/.pipeline/pipeline.toml.
# Most users only need this env var.
SLACK_CHANNEL=

# Optional: restrict button clicks to specific Slack user IDs (comma-separated).
# Find your ID: click your Slack profile -> "..." -> Copy member ID (U0123...).
# Leave blank to allow any user in the channel to click.
SLACK_ALLOWED_USERS=
